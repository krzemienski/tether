# tether — example configuration
# Copy to /etc/tether/dns-env on the relay (mode 0600 root) for cron use,
# or export inline before invoking the install scripts.

# ---- Relay → Client linkage (output of `tether install relay`) ----
TETHER_RELAY="1.2.3.4"                       # relay public IP or hostname
TETHER_SECRET="<64-hex-from-relay-install>"  # shared bore secret
TETHER_REMOTE_PORT="2222"                    # port relay binds for plain ssh
TETHER_LOCAL_PORT="22"                       # local sshd port on the client

# ---- Cloudflare DNS (Mode A — scoped token, recommended) ----
CF_API_TOKEN=""                              # token with Zone:DNS:Edit on CF_ZONE

# ---- Cloudflare DNS (Mode B — legacy global key, fallback) ----
# CF_API_EMAIL="you@example.com"
# CF_API_KEY="<37-char-hex>"

CF_ZONE="example.com"
CF_HOST="m4.example.com"
CF_TARGET_IP=""                              # leave blank to auto-detect public IP
CF_TTL="60"
CF_PROXIED="false"                           # MUST be false for raw TCP (ssh)
